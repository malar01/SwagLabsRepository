package Base;

import java.time.Duration;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.edge.EdgeDriver;
import org.openqa.selenium.safari.SafariDriver;

import UtilityPackage.ConfigReader;

public class Base {
	protected static WebDriver driver; // assessible by subclasses
	
	//initialize the browser
	
	public void setUp() {
		//get browser type, url, wait from ConfigReader utility class
		String browser=ConfigReader.getProperty("browser");
		String url=ConfigReader.getProperty("url");
		long wait=Long.parseLong(ConfigReader.getProperty("timeout"));
		
		//Instantiate WebDriver based on browser type
		switch ("browser"){
			case "chrome": 
				driver=new ChromeDriver();
				break;
			case "safari":
				driver=new SafariDriver();
				break;
			case "edge":
				driver=new EdgeDriver();
				break;
			default:
			throw new RuntimeException("Unsupported Browser: "+ browser);		
		}
		
		//Browser setup
		driver.manage().window().maximize();
		driver.manage().timeouts().implicitlyWait(Duration.ofSeconds(wait));
		driver.get(url);
	}
	public void tearDown() {
		if(driver !=null) {
			driver.quit();//close all browser windows
		}
	}
}